# 后端环境变量配置
# 复制此文件为 .env 并填写真实配置

# 服务端口
PORT=3000
NODE_ENV=production

# JWT 密钥 (请务必修改为随机长字符串)
JWT_SECRET=your_very_secret_key_here_change_me
JWT_EXPIRES_IN=30d

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_change_me

# PostgreSQL 数据库
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shanye_book
DB_USER=postgres
DB_PASSWORD=your_db_password

# Cloudinary 文件存储 (封面图片)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 短信验证码 (腾讯云短信 or 阿里云短信)
SMS_PROVIDER=tencent     # tencent | aliyun
# 腾讯云短信
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=山野村书
TENCENT_SMS_TEMPLATE_ID=

# 微信开放平台
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Apple IAP 验证
# true=沙盒测试, false=生产
APPLE_IAP_SANDBOX=false
